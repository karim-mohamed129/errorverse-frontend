/* =====================================================
   RESET / BASE
   ===================================================== */
html,
body,
#root {
  min-height: 100%;
  height: auto;
  overflow-y:hidden;
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

body {
  margin: 0;
  color: #ffffff;
  font-family: "Neotoxic", Arial, Helvetica, sans-serif;
  overflow-x: hidden;
  overflow-y: auto;
}
body {
  background-repeat: no-repeat;
  background-size: cover;        /* fills screen nicely */
  background-position: center;   /* keeps it centered */
  background-attachment: fixed;  /* optional: subtle parallax feel */
}

/* =====================================================
   PAGE WRAPPER
   ===================================================== */
.home-page {
  position: relative;
  min-height: 100vh;
}

.home-noise {
  position: fixed;
  inset: 0;
  pointer-events: none;
  opacity: 0.16;
  z-index: 0;
}

/* =====================================================
   MAIN CONTENT
   ===================================================== */
main.page-content {
  position: relative;
  z-index: 1;
  width: min(100%, 1920px);
  margin-inline: auto;
  padding-top: 32px;
  padding-left: 50px;
  padding-right: 50px;
  background-position: center;
  background-size: cover;
  background-repeat: no-repeat;
}

/* =====================================================
   SECTIONS
   ===================================================== */
.content-section {
  margin-bottom: 26px;
}

.section-head {
  position: relative;
  margin-bottom: 18px;
}

/* =====================================================
   LOAD MORE BUTTON
   ===================================================== */
.load-more-wrap {
  display: flex;
  justify-content: center;
  margin-top:-10px!important;
  padding-top: 18px;
  border-top: 1px solid rgba(255, 255, 255, 0.15);
}

.load-more-btn {
  min-width: 390px;
  height: 44px;
  border: 1px solid rgba(255, 255, 255, 0.55);
  border-radius: 8px;
  background: #cf4aa4;
  color: #ffffff;
  font-family: "Neotoxic", Arial, Helvetica, sans-serif;
  font-size: 16px;
  font-style: italic;
  line-height: 1;
  text-transform: uppercase;
  box-shadow: 0 0 10px rgba(207, 74, 164, 0.25);
  cursor: pointer;
  transition:
    transform 0.2s ease,
    opacity 0.2s ease,
    box-shadow 0.2s ease;
}

.load-more-btn:hover {
  opacity: 0.96;
  transform: translateY(-1px);
  box-shadow: 0 0 12px rgba(207, 74, 164, 0.32);
}

.load-more-btn:active {
  transform: translateY(0);
}

/* =====================================================
   LANGUAGE TOGGLES
   ===================================================== */
.lang-ar {
  color: #1d1d1d !important;
  font-family: NeoSansArabicLight;
  font-weight: 900;
  font-size: 16px;
  line-height: 100%;
}

.lang-en {
  border: 1px solid #f5f5f5 !important;
  background: linear-gradient(90deg, #1d1d1d -496.04%, #0d0d0d 140.63%) !important;
  box-shadow: 0 0 250px 0 #ffffff !important;
}

/* =====================================================
   GENERIC HELPERS
   ===================================================== */
.line-break {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 20px;
}

.line-break-img {
  width: 100%;
  height: auto;
  display: block;
  pointer-events: none;
}

/* =====================================================
   RESPONSIVE
   ===================================================== */
@media (min-width: 1800px) {
  main.page-content {
    padding-left: 64px;
    padding-right: 64px;
  }
}

@media (max-width: 1399px) {
  main.page-content {
    padding-left: 56px;
    padding-right: 56px;
  }
}

@media (max-width: 1200px) {
  main.page-content {
    padding-left: 40px;
    padding-right: 40px;
  }
}

@media (max-width: 768px) {
  main.page-content {
    padding-left: 24px;
    padding-right: 24px;
  }
}

@media (max-width: 576px) {
  main.page-content {
    padding-top: 18px;
    padding-left: 10px;
    padding-right: 10px;
  }

  .content-section {
    margin-bottom: 32px;
  }

  .section-head {
    margin-bottom: 12px;
  }

  .load-more-btn {
    min-width: 220px;
    font-size: 14px;
  }
}